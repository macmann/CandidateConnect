# OpenAI key used for per-application CV and cover letter customization
OPENAI_API_KEY=your_openai_api_key_here

# Existing AI feature for answer generation (optional, if used)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Neon SQL HTTP configuration (optional).
# When configured, profile + document repositories use Neon Postgres.
NEON_SQL_ENDPOINT=https://<your-neon-sql-http-endpoint>
NEON_SQL_API_KEY=your_neon_sql_http_api_key

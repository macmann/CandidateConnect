# OpenAI key used for per-application CV and cover letter customization
OPENAI_API_KEY=your_openai_api_key_here

# Existing AI feature for answer generation (optional, if used)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Neon Postgres configuration (optional).
# Preferred: standard Postgres connection string from Neon (pooler URL).
DATABASE_URL=postgresql://neondb_owner:<password>@<your-neon-pooler-host>/neondb?sslmode=require&channel_binding=require

# Optional explicit Neon SQL-over-HTTP config.
# If set, these take precedence over DATABASE_URL.
NEON_SQL_ENDPOINT=https://<your-neon-sql-http-endpoint>
NEON_SQL_API_KEY=your_neon_sql_http_api_key
